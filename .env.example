# Copy this file to .env for local use, or set these in your hosting
# platform's environment variables settings (e.g. Railway > Variables).

# Required in production — any long random string
SESSION_SECRET=change-this-to-a-long-random-string

# Set NODE_ENV=production when deployed so secure cookies are enabled
NODE_ENV=development

# Admin login — change these before your first deploy!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ACEsu_052902

# Set to false in production if you don't want the 3 sample residents seeded
SEED_SAMPLE_DATA=true

# --- MySQL connection ---
# For local development with MySQL Workbench, these usually match whatever
# connection you set up there (default local server is host=localhost, port=3306).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ACEsu_052902
DB_NAME=barangay_db

# Usually set automatically by the hosting platform — no need to set this yourself
PORT=3000
